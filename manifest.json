{
  "manifest_version": 3,
  "name": "Block Extension",
  "version": "1.0",
  "description": "Example Firefox extension",
  "action": {
    "default_popup": "popup/popup.html",
    "default_title": "Block Extension"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content_scripts/content.js"]
    }
  ],
  "permissions": ["activeTab"]
}
